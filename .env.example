# ── Chain ──────────────────────────────────────────────────────────────────────
CHAIN_ID=8453                         # Base mainnet
RPC_URL=https://mainnet.base.org

# ── Contract addresses ─────────────────────────────────────────────────────────
USDC_ADDRESS=0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913    # USDC on Base
MORPHO_VAULT=0x...                    # Initial Morpho ERC4626 vault address (must be whitelisted)
VAULT_OWNER=0x...                     # Multisig that owns UMYOVault
KEEPER=0x...                          # Keeper EOA authorized to call rebalance()
CONTRACT_ADDRESS=0x...                # Deployed UMYOVault address (set after deploy)

# ── Deployer ───────────────────────────────────────────────────────────────────
PRIVATE_KEY=0x...                     # Deployer private key (never commit the real value)

# ── Keeper settings ────────────────────────────────────────────────────────────
MIN_APY_IMPROVEMENT=0.5               # Minimum APY delta (%) to trigger rebalance
